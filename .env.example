```env
# =========================
# DATABASE CONFIG
# =========================

# PostgreSQL (AI service)
POSTGRES_USER="postgres"
POSTGRES_PASSWORD="YourStrong!Passw0rd"
POSTGRES_DB="appdb"

# SQL Server (C# backend)
SA_PASSWORD="YourStrong!Passw0rd"


# =========================
# API CONFIG
# =========================

# Port chạy trong container (KHÔNG phải localhost)
ASPNETCORE_URLS=http://+:5000

# URL nội bộ gọi AI service (dùng tên service, KHÔNG dùng localhost)
AI_SERVICE_URL=http://ai-service:8000


# =========================
# AI SERVICE CONFIG
# =========================

# URL nội bộ gọi về API
BACKEND_API_URL=http://api:5000
```
